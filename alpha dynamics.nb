Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"DSolve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
    RowBox[{"Simplify", "[", 
     RowBox[{
      RowBox[{"Sin", "[", 
       RowBox[{"3", "*", 
        RowBox[{"y", "[", "x", "]"}]}], "]"}], "/", 
      RowBox[{"(", 
       RowBox[{"M", "*", 
        RowBox[{"3", "^", 
         RowBox[{"(", 
          RowBox[{"1", "/", "4"}], ")"}]}], " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"2", " ", "*", 
          RowBox[{"Sin", "[", 
           RowBox[{"2", "*", 
            RowBox[{"y", "[", "x", "]"}]}], "]"}]}], "]"}], "*", 
        RowBox[{
         RowBox[{"Sin", "[", 
          RowBox[{"y", "[", "x", "]"}], "]"}], "^", "2"}], " ", "*", "dphi"}],
        "  ", ")"}]}], "]"}]}], ",", 
   RowBox[{"y", "[", "x", "]"}], ",", "x"}], "]"}]], "Input",
 CellChangeTimes->{{3.919943221599186*^9, 3.9199432508556013`*^9}},
