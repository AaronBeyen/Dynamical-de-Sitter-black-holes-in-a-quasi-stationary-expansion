 RowBox[{"Simplify", "[", 
  RowBox[{
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", "-", 
       RowBox[{"Cos", "[", 
        RowBox[{"2", " ", "x"}], "]"}]}], ")"}], " ", 
     RowBox[{"Cos", "[", 
      RowBox[{"3", " ", "x"}], "]"}], " ", 
     SuperscriptBox[
      RowBox[{"Csc", "[", "x", "]"}], "2"]}], 
    RowBox[{"18", " ", 
     SqrtBox["2"], " ", 
     SuperscriptBox["3", 
      RowBox[{"1", "/", "4"}]], " ", "mm", " ", 
     SqrtBox[
      RowBox[{"Sin", "[", 
       RowBox[{"2", " ", "x"}], "]"}]]}]], "-", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", "*", 
       RowBox[{
        RowBox[{"Sin", "[", "x", "]"}], "^", "2"}]}]}], ")"}], "*", 
    RowBox[{
     RowBox[{"Cos", "[", 
      RowBox[{"3", "*", "x"}], "]"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"108", "^", 
        RowBox[{"(", 
         RowBox[{"3", "/", "4"}], ")"}]}], "*", "mm", "*", 
       RowBox[{
        RowBox[{"Sin", "[", "x", "]"}], "^", "2"}], "*", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Sin", "[", 
         RowBox[{"2", "*", "x"}], "]"}], "]"}]}], ")"}]}]}]}], "]"}]], "Input",
