Cell[BoxData[
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"(", "12", ")"}], "^", 
       RowBox[{"(", 
        RowBox[{"3", "/", "4"}], ")"}]}], "*", 
      RowBox[{"Sin", "[", "x", "]"}], "*", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Sin", "[", 
         RowBox[{"2", "*", "x"}], "]"}], "]"}], "/", 
       RowBox[{"Cos", "[", 
        RowBox[{"3", "*", "x"}], "]"}]}], "*", "M"}], "==", "1"}], " ", "&&", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"2", "^", 
        RowBox[{"(", 
         RowBox[{"3", "/", "2"}], ")"}]}], "/", 
       RowBox[{"3", "^", 
        RowBox[{"(", 
         RowBox[{"1", "/", "4"}], ")"}]}]}], "*", "M", "*", 
      RowBox[{"Sin", "[", "x", "]"}], "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"Sin", "[", 
        RowBox[{"2", "*", "x"}], "]"}], "]"}]}], "==", "1"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"x", ",", "M"}], "}"}]}], "]"}]], "Input",
